# Git ignore for ~/.claude/

# Exclude runtime/session files (Claude Code internals)
debug/
downloads/
file-history/
history.jsonl
ide/
plugins/
projects/
session-env/
shell-snapshots/
statsig/
todos/
settings.json
.DS_Store

# Keep these (our configuration)
!rules/
!agents/
!commands/
!templates/
!README.md
!.gitignore

# Credentials and secrets
.credentials.json

# Cache and local state
cache/
stats-cache.json
mcp-needs-auth-cache.json

# Local backups and session data
backups/
plans/
telemetry/

# Exclude stray CLAUDE.md (projects have their own)
CLAUDE.md

# Claude Code internal directories
.claude/
paste-cache/
sessions/
tasks/
